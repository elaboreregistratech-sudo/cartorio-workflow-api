generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  ANALYST
  ATTENDANT
}

enum ProtocolStatus {
  DRAFT
  IN_REVIEW
  PENDING_DOCUMENTS
  APPROVED
  REJECTED
  COMPLETED
}

enum WorkflowStepStatus {
  PENDING
  IN_PROGRESS
  DONE
  BLOCKED
}

enum DocumentStatus {
  PENDING
  VALID
  INVALID
}

model User {
  id           String      @id @default(cuid())
  fullName     String
  email        String      @unique
  passwordHash String
  role         UserRole    @default(ANALYST)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  protocols    Protocol[]  @relation("ProtocolCreatedBy")
  workflows    Workflow[]  @relation("WorkflowAssignedTo")
}

model Protocol {
  id             String           @id @default(cuid())
  code           String           @unique
  applicantName  String
  applicantCpf   String
  serviceType    String
  description    String?
  status         ProtocolStatus   @default(DRAFT)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdById    String
  createdBy      User             @relation("ProtocolCreatedBy", fields: [createdById], references: [id])
  documents      Document[]
  workflows      Workflow[]
}

model Document {
  id           String          @id @default(cuid())
  protocolId   String
  protocol     Protocol        @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  name         String
  type         String
  fileUrl      String?
  status       DocumentStatus  @default(PENDING)
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model Workflow {
  id            String              @id @default(cuid())
  protocolId    String
  protocol      Protocol            @relation(fields: [protocolId], references: [id], onDelete: Cascade)
  title         String
  description   String?
  order         Int
  status        WorkflowStepStatus  @default(PENDING)
  assignedToId  String?
  assignedTo    User?               @relation("WorkflowAssignedTo", fields: [assignedToId], references: [id])
  dueDate       DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
}
